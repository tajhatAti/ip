# ===========================================
# Ahad Co - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to GitHub!
# ===========================================

# Email Service (Brevo/Sendinblue)
BREVO_API_KEY=your_brevo_api_key_here
SENDER_EMAIL=noreply@yourdomain.com
SENDER_NAME=Ahad Co

# ---------------------------------------------------------------------------
# DATABASE
# ---------------------------------------------------------------------------
# Leave DATABASE_URL UNSET to use a local SQLite file (great for development —
# zero setup). Set it to a postgresql:// URL to use PostgreSQL (Supabase free
# tier) so your data persists permanently.
#
# Get this from Supabase Dashboard -> Project Settings -> Database ->
# "Connection string" -> "Session pooler" (port 5432) or "Transaction pooler"
# (port 6543). Paste it here, replacing [YOUR-PASSWORD].
#
#   DATABASE_URL=postgresql://postgres.xxxx:YOUR_PASSWORD@aws-0-region.pooler.supabase.com:5432/postgres
#
# When DATABASE_URL is unset, the app uses the SQLite file at DB_PATH instead:
DB_PATH=/app/data/database.db

# SSL mode for PostgreSQL. Supabase & most managed Postgres require SSL.
# "prefer" (default) uses SSL when available and falls back otherwise.
# Use "require" to force SSL, or "disable" for a local no-SSL dev server.
# PG_SSLMODE=prefer

# OTP Settings
OTP_EXPIRY_MINUTES=10

# Python Version
PYTHON_VERSION=3.11
